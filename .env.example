# ---------------------------------------------------------------------------
# Apexcheck — environment variables
# Copy this file to `.env.local` and fill in real values.
# The app runs WITHOUT most of these in local dev (see notes below).
# ---------------------------------------------------------------------------

# --- Database -------------------------------------------------------------
# Leave blank in local dev to use an ephemeral in-memory MongoDB (auto-seeded,
# not persisted). Set a real MongoDB Atlas URI for persistence / production.
MONGODB_URI=mongodb+srv://katalystiq_db_user:KgsVAfL0fEj3JRGu@scrappey.4mg4wvr.mongodb.net/?appName=Scrappey
MONGODB_DB=apexcheck

# --- Admin auth -----------------------------------------------------------
# Sign-in email for the single admin account.
ADMIN_EMAIL=admin@apexcheck.local
# Preferred: a bcrypt hash of the admin password. Generate one with:
#   npm run hash-password -- "your-password-here"
# IMPORTANT: Next.js expands $VAR inside .env* files, and bcrypt hashes are
# full of $-prefixed segments (e.g. $2b$10$...). Escape every $ as \$ or the
# hash gets silently mangled and login will fail with no useful error.
ADMIN_PASSWORD_HASH=
# Dev-only fallback: plaintext password used when no hash is set. Do NOT use in prod.
ADMIN_PASSWORD=admin1234
# Secret used to sign the admin session JWT. Use a long random string in prod.
JWT_SECRET=change-me-to-a-long-random-string

# --- Cloudinary (image + document uploads) -------------------------------
# Without these, the item editor falls back to storing uploads on local disk
# under /public/uploads (dev only).
CLOUDINARY_CLOUD_NAME=dowgpldtj
CLOUDINARY_API_KEY=137634112889561
CLOUDINARY_API_SECRET=3m9z0e1PCih7AH1GeqJjKmVB9is
CLOUDINARY_UPLOAD_FOLDER=apexcheck

# --- Email notifications (Resend) -----------------------------------------
# When unset, new-inquiry notifications are logged to the server console.
RESEND_API_KEY=
EMAIL_FROM=Apexcheck <onboarding@resend.dev>
ADMIN_NOTIFICATION_EMAIL=

# --- Public site config (safe to expose to the browser) -------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BUSINESS_NAME=Apexcheck Medical
NEXT_PUBLIC_BUSINESS_TAGLINE=
# WhatsApp number in international format, digits only (no +).
NEXT_PUBLIC_WHATSAPP_NUMBER=234200000000
NEXT_PUBLIC_CONTACT_PHONE=
NEXT_PUBLIC_CONTACT_EMAIL=
# Online-only business — no physical address field.
NEXT_PUBLIC_YEARS_IN_OPERATION=5
NEXT_PUBLIC_DELIVERY_COVERAGE=

# --- Paystack (scaffolded, not wired to a live charge flow yet) ------------
PAYSTACK_SECRET_KEY=sk_test_70cf4a3eb24ea3c5fa67d13cb3007a513bd6f6cc
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_a1c3176561ffdc703cbde32cd2474a49581fa857
